# Database Connection URL
# SQLite default: sqlite:///leadpilot.db
# PostgreSQL / Supabase format: postgresql://username:password@host:port/database
DATABASE_URL=sqlite:///leadpilot.db

# LLM API Keys
GROQ_API_KEY=your_groq_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# Search API Key
SERPER_API_KEY=your_serper_api_key_here

# Outreach Email Configuration
SENDGRID_API_KEY=your_sendgrid_api_key_here
DEFAULT_SENDER_EMAIL=your_verified_sender_email@company.com
DEFAULT_SENDER_NAME="Your Name"

# Optional SMTP Settings (Used as default if custom SMTP is selected)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_username
SMTP_PASSWORD=your_password
